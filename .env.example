# Supabase Configuration (Required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role (Required for setup scripts only - NEVER expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Site URL (Required - used for SEO, sitemap, and absolute URLs)
NEXT_PUBLIC_SITE_URL=https://your-site.vercel.app

# Optional: Google Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Optional: Mercado Pago (for payment integration)
MP_ACCESS_TOKEN=your-mp-access-token-here

# Optional: Admin email whitelist (comma-separated)
# If set, only these emails can access admin endpoints. If not set, any authenticated user can.
ADMIN_EMAILS=admin@example.com,owner@example.com
